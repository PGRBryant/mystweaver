# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

project_id  = "your-gcp-project-id"
region      = "us-central1"
github_org  = "yourusername"
github_repo = "mystweaver"

# Redis — use STANDARD_HA in production for high availability
redis_tier           = "BASIC"
redis_memory_size_gb = 1

# Monitoring
alert_email = "you@example.com"

# Load Balancer + IAP
domain                  = "mystweaver.dev"
iap_oauth_client_id     = "your-oauth-client-id.apps.googleusercontent.com"
iap_oauth_client_secret = "your-oauth-client-secret"
iap_members             = ["user:you@gmail.com"]
