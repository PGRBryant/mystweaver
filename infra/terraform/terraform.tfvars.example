# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

project_id  = "your-gcp-project-id"
region      = "us-central1"
github_org  = "yourusername"
github_repo = "mystweaver"

# Monitoring
alert_email = "you@example.com"

# Load Balancer + IAP
domain                  = "mystweaver.dev"
iap_oauth_client_id     = "your-oauth-client-id.apps.googleusercontent.com"
iap_oauth_client_secret = "your-oauth-client-secret"
# IAP authorized users are configured in GCP Console → Security → Identity-Aware Proxy
