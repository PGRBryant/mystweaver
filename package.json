{
  "name": "@mystweaver/monorepo",
  "version": "0.1.0",
  "description": "An open-source feature flag and experimentation platform, self-hosted LaunchDarkly alternative",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/sdk-js"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "seed": "tsx scripts/seed-flags.ts",
    "clean": "npm run clean --workspaces && rimraf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "packageManager": "npm@9.0.0+",
  "repository": {
    "type": "git",
    "url": "https://github.com/PGRBRyant/mystweaver"
  },
  "bugs": {
    "url": "https://github.com/PGRBRyant/mystweaver/issues"
  },
  "homepage": "https://github.com/PGRBRyant/mystweaver"
}
